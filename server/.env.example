NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rawat-organics

# JWT — use long random strings in production (min 32 chars)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_xxxx
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_xxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_MAX=100

# CORS — comma-separated for multiple origins
CORS_ORIGIN=http://localhost:3000

# Seeder (only used by npm run seed)
SUPER_ADMIN_EMAIL=admin@rawatorganics.com
SUPER_ADMIN_PASSWORD=Admin@123456
